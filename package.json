{
  "name": "@amitgurbani/mcp-server-woocommerce",
  "mcpName": "io.github.AmitGurbani/mcp-server-woocommerce",
  "version": "1.1.0",
  "description": "MCP server for managing WooCommerce stores through AI assistants",
  "type": "module",
  "author": "Amit Gurbani",
  "license": "MIT",
  "homepage": "https://github.com/AmitGurbani/mcp-server-woocommerce",
  "bugs": {
    "url": "https://github.com/AmitGurbani/mcp-server-woocommerce/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AmitGurbani/mcp-server-woocommerce.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "woocommerce",
    "model-context-protocol",
    "claude",
    "ai",
    "wordpress",
    "ecommerce",
    "store-management",
    "automation",
    "integration",
    "api"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "mcp-server-woocommerce": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf build",
    "build": "pnpm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "prepublishOnly": "pnpm run build",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@woocommerce/woocommerce-rest-api": "^1.0.2",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
