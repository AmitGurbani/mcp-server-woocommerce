# Required
WORDPRESS_SITE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_your_key
WOOCOMMERCE_CONSUMER_SECRET=cs_your_secret

# Optional (needed for media tools)
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# HTTP Transport (set MCP_TRANSPORT=http for remote access)
# MCP_TRANSPORT=http
# MCP_PORT=3000
# MCP_AUTH_TOKEN=your-secret-token

# OAuth 2.1 via Auth0 (for Claude.ai web/mobile Connectors)
# AUTH0_DOMAIN=https://your-tenant.us.auth0.com
# AUTH0_AUDIENCE=https://mcp.yourstore.com
# MCP_SERVER_URL=https://your-app.railway.app/mcp

# Safety
# WOOCOMMERCE_MCP_READ_ONLY=true
