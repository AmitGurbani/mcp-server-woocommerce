# Required
WORDPRESS_SITE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_your_key
WOOCOMMERCE_CONSUMER_SECRET=cs_your_secret

# Optional (needed for media tools)
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Agent Orchestration (optional — for Paperclip users)
# See docs/ORCHESTRATION.md for setup details
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_COMPANY_ID=your_company_id
PAPERCLIP_AGENT_ID=your_agent_id
PAPERCLIP_API_KEY=pcp_your_api_key
